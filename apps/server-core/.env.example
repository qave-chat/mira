# Server-core env vars.
#
# Local dev: see .env.local (auto-loaded by Bun, committed with placeholder values).
# Prod: these are injected by CDK (apps/server-core deployed to ECS) — keep in sync.

# HTTP
PORT=38412

# Better-auth (required in prod; .env.local has dev placeholders)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://example.com
BETTER_AUTH_TRUSTED_ORIGINS=https://example.com

# Google OAuth — real values in prod; .env.local points to local emulator
GOOGLE_CLIENT_ID=local-client.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-local-secret
# AUTH_GOOGLE_DISCOVERY_URL only set in dev to override the default Google discovery URL.
# AUTH_GOOGLE_DISCOVERY_URL=http://localhost:4000/.well-known/openid-configuration

# AI
OPENAI_API_KEY=

# Database — dev uses .env.local; prod uses CDK-injected DB_HOST/DB_PORT/DB_NAME/DB_USERNAME/DB_PASSWORD
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agent
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Session EC2 readiness. Omit in prod to require the private-IP MiniStack health check.
# SESSION_EC2_HEALTH_CHECK_MODE=skip

# R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
